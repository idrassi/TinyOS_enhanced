# ============================================================================
# TinyOS Enhanced — .gitignore
# ============================================================================

# --- Build artifacts ---
*.o
*.a
*.elf
*.bin
*.iso
*.d
bin/
dist/
build/
# built kernel copied into the ISO tree:
iso/boot/kernel.elf

# --- Disk images ---
*.img
*.qcow2

# --- Keys / secrets — NEVER commit private key material ---
# (src/trusted_signing_key.h is the PUBLIC verification key and IS tracked.)
*.pem
*.key
id_rsa
id_ed25519
hardcoded_rsa_keys.h
host_rsa_key_details.txt
host_rsa_key.pem
keys/

# --- Runtime / debug capture artifacts ---
serial.log
serial_*.log
panic.log
qemu.log
*.pcap
network_trace.txt
log/
firstexec-trials.log

# --- Personal ops scripts (not part of the OS; reference a specific GitHub repo) ---
publish.sh

# --- Vendored / generated, not project source ---
lib/
pyvenv.cfg
__pycache__/
*.pyc
screenshots/
*.mov
*.tar.gz

# --- Ad-hoc developer test scripts / host-side reference programs ---
# Not part of the published product (the canonical harness is verify-exec.sh at
# the repo root). Kept on disk locally; not tracked or published.
test/

# --- SSH/SSHD/RSA removed from the build (kept on disk, not compiled) ---
src/ssh.c
src/ssh.h
src/ssh_crypto.c
src/ssh_crypto.h
src/rsa.c
src/rsa.h
src/ssh.c.backup
src/ssh.c.bak
src/ssh_clean.txt

# --- OS / editor cruft ---
.DS_Store
.playwright-mcp/

# --- Historical / superseded docs cut from the public set (kept on disk, not published) ---
# The public repo ships a curated 13-doc set; everything below is retained locally
# only. publish.sh exports `git archive HEAD` (tracked files only), so these never
# reach GitHub regardless — these patterns just keep them out of the index too.
firstexec-trial.sh
doc/AI_PROMPTING_GUIDE_FOR_OS_DEVELOPMENT.md
doc/ARP_CACHE_LEARNING_FIX.md
